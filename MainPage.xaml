<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
x:Class="QuizMauiApp.MainPage" 
Title="Accueil">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">
            <Label Text="🏆" 
                   FontSize="72" 
                   HorizontalTextAlignment="Center" />
            <Label Text="Quiz Challenge" 
                   FontSize="30" 
                   FontAttributes="Bold" 
                   HorizontalTextAlignment="Center" 
                   TextColor="DarkBlue" />
            <Label Text="Bienvenue dans votre première application mobile .NET MAUI. 
Testez vos connaissances en choisissant une catégorie." 
                   FontSize="16" 
                   HorizontalTextAlignment="Center" />
            <Button Text="Commencer le quiz" 
                    FontSize="18" 
                    HeightRequest="55" 
                    WidthRequest="220" 
                    CornerRadius="12" 
                    BackgroundColor="DarkBlue" 
                    TextColor="White" 
                    HorizontalOptions="Center" 
                    Clicked="OnStartClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>